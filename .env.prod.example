# RUBLI Production Environment
# Copy this file to .env.prod and fill in your values
# Usage: docker-compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Public URL(s) of your server (comma-separated). Used for CORS.
# Must include the exact origin browsers will use (protocol + domain + port if non-standard).
# Examples:
#   CORS_ORIGINS=https://rubli.xyz
#   CORS_ORIGINS=https://rubli.xyz,http://37.60.232.109
CORS_ORIGINS=https://rubli.xyz

# Secret key for write API endpoints (watchlist, feedback, ARIA review).
# Generate with: openssl rand -hex 32
# REQUIRED — docker compose up will abort if this is not set.
RUBLI_WRITE_KEY=change-me-generate-with-openssl-rand-hex-32

# Email address for Let's Encrypt certificate renewal notifications.
# REQUIRED for Caddy TLS. Use the domain owner's email.
ACME_EMAIL=admin@rubli.xyz

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# API base URL exposed in the frontend build (baked in at build time by Vite).
# Defaults to the server origin at runtime if not set.
# VITE_APP_URL=https://rubli.xyz

# Backend log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# Backend query timeout in seconds (default: 30)
# DB_QUERY_TIMEOUT=30

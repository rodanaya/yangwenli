# Cursor indexer ignore — keeps large/irrelevant files out of AI context.
# Cursor also respects .gitignore, so *.db, node_modules/, __pycache__/ are
# already excluded there. This file handles git-tracked files we don't want indexed.

# Large methodology docs — too long, dominate context window
docs/RISK_METHODOLOGY_v5.md
docs/RISK_METHODOLOGY_v4.md
docs/RISK_METHODOLOGY.md
docs/MODEL_COMPARISON_REPORT.md

# Large seed / data files
backend/data/scandals_seed.json

# Migration / recovery scripts — historical, not active code
backend/scripts/rollback_to_v51.py
backend/scripts/recover_db*.py

# Generated / compiled
frontend/dist/
frontend/.vite/
backend/**/__pycache__/

# Large ETL scripts (read individually if needed)
backend/scripts/etl_pipeline.py
backend/scripts/calculate_risk_scores_v5.py
backend/scripts/compute_z_features.py

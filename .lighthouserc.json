{
  "ci": {
    "collect": {
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.85 }],
        "categories:best-practices": ["warn", { "minScore": 0.80 }],
        "categories:seo": ["warn", { "minScore": 0.80 }],
        "categories:performance": ["warn", { "minScore": 0.60 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}

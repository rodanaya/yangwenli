# RUBLI Caddy Configuration
# Handles HTTPS with automatic Let's Encrypt certificates.
# ACME_EMAIL env var is used for cert renewal notifications.

{
    email {$ACME_EMAIL}
}

# Serve via domain with HTTPS (active once DNS is pointed at this server)
rubli.xyz {
    reverse_proxy frontend:80
}

www.rubli.xyz {
    redir https://rubli.xyz{uri} permanent
}

vizsga.rubli.xyz {
    reverse_proxy magyar:8000
}

# Bare-IP fallback: redirect all plain-HTTP requests to the canonical domain
:80 {
    redir https://rubli.xyz{uri} permanent
}
